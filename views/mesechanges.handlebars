<div class="container mt-5">
    <h1 class="mb-4">Mes Échanges</h1>
    <div class="row">
        {{#each echanges}}
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">{{nom_echange}}</h5>
                    <p class="card-text">Proposé par : {{nom_utilisateur}}</p>
                    <a href="/echange/{{id_echange}}" class="btn btn-warning">Voir l'échange</a>
                    <form action="/supprimerechange/{{id_echange}}" method="POST" class="mt-2">
                        <button type="submit" class="btn btn-danger">Supprimer</button>
                    </form>
                </div>
            </div>
        </div>
        {{/each}}
    </div>
</div>